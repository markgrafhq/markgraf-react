{
  "name": "@markgrafhq/markgraf-react",
  "version": "0.0.30",
  "description": "React hook + component for embedding markgraf animations. Drives play/pause/seek and exposes time + keyframe as reactive state.",
  "type": "module",
  "main": "./dist/markgraf-react.js",
  "module": "./dist/markgraf-react.js",
  "types": "./dist/markgraf-react.d.ts",
  "style": "./dist/markgraf-react.css",
  "exports": {
    ".": {
      "types": "./dist/markgraf-react.d.ts",
      "default": "./dist/markgraf-react.js"
    },
    "./css": {
      "style": "./dist/markgraf-react.css",
      "default": "./dist/markgraf-react.css"
    },
    "./dist/CommitMono-Regular.woff2": "./dist/CommitMono-Regular.woff2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/markgraf-react.css"
  ],
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.14",
    "vite": "^5.4.11"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "keywords": [
    "markgraf",
    "react",
    "hook",
    "animation",
    "diagram",
    "canvas"
  ],
  "license": "MIT",
  "author": "Mark Eibes <mark.eibes@gmail.com>",
  "homepage": "https://github.com/markgrafhq/markgraf-react#readme",
  "bugs": "https://github.com/markgrafhq/markgraf-react/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markgrafhq/markgraf-react.git"
  }
}
