{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "lib": ["es2020", "dom"],
    "paths": {
      "@markgrafhq/markgraf-react": ["../dist/markgraf-react.d.ts"]
    },
    "types": ["react"]
  },
  "include": ["*.tsx", "*.ts"]
}
